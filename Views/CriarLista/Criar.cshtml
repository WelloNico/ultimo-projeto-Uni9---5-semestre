@model Compraí____Listas_compartilhadas.Models.CriarListaViewModel


@{
    ViewData["Title"] = "Criar nova lista";
}

@section Styles {
    <link rel="stylesheet" href="~/css/criarLista.css" />
}

<div class="criar-lista-container">

    <h1 class="page-title">
        Criar nova lista compartilhada
    </h1>


    <div class="lista-card">

        <form asp-action="Criar" method="post">

            <div class="mb-4">

                <label asp-for="NomeLista">
                    Nome da Lista
                </label>

                <input asp-for="NomeLista"
                       class="form-control" />

            </div>

            <h4 class="section-title">
                Cadastre abaixo seus produtos
            </h4>

            <p class="section-subtitle">
                Cadastre pelo menos 1 item pra gerar a nova lista
            </p>

            <table class="table table-dark align-middle" id="tabelaProdutos">

                <thead class="Cadastro_itens">
                    <tr >
                        <th scope="col">Produto</th>
                        <th scope="col">Marca</th>
                        <th scope="col">Quantidade</th>
                        <th scope="col">Preço</th>
                        <th scope="col"></th>
                    </tr>
                </thead>

                <tbody>

                    @for (int i = 0; i < Model.Produtos.Count; i++)
                    {
                        <tr>

                            <td>
                                <input asp-for="Produtos[i].Produto"
                                       class="form-control"
                                       placeholder="Digite o nome do produto" />
                            </td>

                            <td>
                                <input asp-for="Produtos[i].Marca"
                                       class="form-control"
                                       placeholder="Selecione a marca" />
                            </td>

                            <td style="width: 150px;">
                                <input asp-for="Produtos[i].Quantidade"
                                       class="form-control" />
                            </td>

                            <td style="width: 180px;">
                                <input asp-for="Produtos[i].Preco"
                                       class="form-control" />
                            </td>

                            <td style="width: 80px;">
                                <button type="button"
                                        class="btn btn-outline-light">
                                    <img src="~/css/assets/CriarNovaLista\IconeDeletaLista.svg" alt="Icone Deleta Lista" />
                                </button>
                            </td>

                        </tr>
                    }
                   
                </tbody>

            </table>


            <div class="mt-3">

                <button type="button"
                        class="btn-adicionar"
                        id="btnAdicionar">
                    Adicionar
                </button>

            </div>

            <div class="mt-4">

                <button type="submit"
                        class="btn-salvar">
                    Salvar Lista
                </button>

            </div>

        </form>

    </div>

</div>