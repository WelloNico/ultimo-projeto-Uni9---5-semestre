@model IEnumerable<Compraí____Listas_compartilhadas.Models.InicialViewModel>

@{
    ViewData["Title"] = "Inicial";
}

<!DOCTYPE html>
<html lang="pt-br">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Login - Compraí</title>  @* Depois aqui vai um  (arroba)Model.NomeLista pra puxar o nomme  da lista atual *@
        <link rel="stylesheet" href="~/css/Inicial.css" />
    </head>
    
    <body>

        <h1 class="titulo-app">Compraí</h1>

        <div class="busca-lista">
            <form method="get" asp-action="Index">
                <input type="text" name="nomeLista" placeholder=" Busque por uma lista" class="campo-busca" />
                <button type="submit" class="btn-buscar">Buscar</button>
            </form>
        </div>

        <div class="pagina-inicial">

            <div class="header-inicial">
                <h2 class="Nome-lista">Nome da lista</h2>
                <div class="acoes">
                    <button type="button" class="btn btn-outline-danger">
                        <img src="~/css/assets/inicial/IconeDeletaLista.svg" alt="Deletar Item da Lista" />
                     </button>

                    <button type="button" class="btn btn-outline-success">
                        <img src="~/css/assets/inicial/IconeAddItemLista.svg" alt="Incluir item na Lista" />
                    </button>
                </div>
            </div>
            <table class="table table-dark">
                <thead>
                    <tr>
                        <th scope="col">QTD</th>
                        <th scope="col">Produto</th>
                        <th scope="col">Marca</th>
                        <th scope="col">Preço</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Quantidade</td>
                                <td>@item.Produto</td>
                                <td>@item.Marca</td>
                                <td>R$ @item.Preco</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center">Nenhum item na lista</td>
                        </tr>
                    }
                </tbody>
            </table>

        <div class="Valores">
            <div class="Valores-card">
                    <span>Total compra</span>
                <strong>R$ --</strong> @*<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<< AQUI VAI REFERENCIAR A MODEL QUE VAI PUXAR OS DADOS DO BANCO *@
                </div>
            <div class="Valores-card">
                    <span>Contribuição</span>
                <strong>R$ --</strong>  @*<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<< AQUI VAI REFERENCIAR A MODEL QUE VAI PUXAR OS DADOS DO BANCO *@
            </div>
        </div>

        <div class="status-compra">
                <p>Status da compra</p>
                <div class="status-icons">
                    <div>
                        <img src="~/css/assets/inicial/IconeStatusAguardando.svg" alt="Pendente" />
                    </div>
                    <span class="seta">→</span>

                    <div>
                        <img src="~/css/assets/inicial/IconeStatusComprando.svg" alt="Comprando" />
                    </div>
                    <span class="seta">→</span>
                    
                    <div>
                        <img src="~/css/assets/inicial/IconeStatusConcluido.svg" alt="Concluído" />
                    </div>
                </div>
        </div>

        </div>
    </body>

</html>
