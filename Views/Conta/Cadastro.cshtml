@model Compraí____Listas_compartilhadas.Models.CadastroViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cadastro - Compraí</title>
    <link rel="stylesheet" href="~/css/conta.css" />
</head>
<body>
    <div class="container">
        <div class="lado-esquerdo">
            <div class="icone-usuario"><img src="~/css/assets/cadastro/add-user.svg" alt="Icone de usuario" /></div>
            <h2>Crie sua conta</h2>
            <p>Preencha os dados ao lado e colabore com as listas do Compraí.</p>
            <img src="~/css/assets/cadastro/prancheta.svg" alt="Icone de usuario" class="icone-prancheta" />
        </div>

        <div class="lado-direito">
            <h1>Cadastrar novo usuario Compraí</h1>
            <p class="subtitulo">Informe seus dados para criar sua conta</p>

            <form asp-action="Cadastro" method="post">
                <div class="form-group">
                    <label asp-for="NomeCompleto">Nome completo</label>
                    <input asp-for="NomeCompleto" placeholder="Digite seu nome completo" />
                    <span asp-validation-for="NomeCompleto" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Email">E-mail</label>
                    <input asp-for="Email" placeholder="Digite seu e-mail" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Senha">Senha</label>
                    <input asp-for="Senha" type="password" placeholder="Digite sua senha" />
                    <span asp-validation-for="Senha" class="text-danger"></span>
                </div>

                <button type="submit" class="btn-cadastrar">Cadastrar conta</button>
            </form>

            <p class="link-login">Já tem uma conta? <a asp-action="Login">Entrar</a></p>
        </div>
    </div>
</body>
</html>