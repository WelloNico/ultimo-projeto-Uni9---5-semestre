@model Compraí____Listas_compartilhadas.Models.LoginViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-br">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Login - Compraí</title>
        <link rel="stylesheet" href="~/css/conta.css" />
    </head>

    <body>
        <div class="container-login">

            <h1>Insira seus dados de acesso abaixo</h1>
        <form class="form-login" asp-action="Login" method="post">
                <div class="form-group">
                    <label for="exampleInputEmail1">Email</label>
                    <input asp-for="Email"  type="email" class="form-control" id="exampleInputEmail1" aria-describedby="emailHelp">

                </div>
                <div class="form-group">
                    <label for="exampleInputPassword1">Password</label>
                    <input asp-for="Senha" type="password" class="form-control" id="exampleInputPassword1">
                </div>
                <button type="submit" class="btn btn-primary">Entrar</button>

                <p class="link-login">Não tem uma conta? <a asp-action="Cadastro">Cadastre-se</a></p>
            </form>
        </div>
    </body>
</html>